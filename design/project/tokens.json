{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "段取りくん — Design Tokens v1.0 · 2026-05-22",
  "color": {
    "primary": {
      "default":     { "value": "#1E3A8A", "type": "color", "$description": "CTA・リンク・見出し強調・選択中タブ" },
      "hover":       { "value": "#1E40AF", "type": "color" },
      "light":       { "value": "#DBEAFE", "type": "color", "$description": "バッジ背景・選択中行ハイライト" }
    },
    "success": {
      "default": { "value": "#10B981", "type": "color", "$description": "完了・対応可・成功" },
      "light":   { "value": "#D1FAE5", "type": "color" }
    },
    "warning": {
      "default": { "value": "#F59E0B", "type": "color", "$description": "業者未確認・対応待ち" },
      "light":   { "value": "#FEF3C7", "type": "color" }
    },
    "danger": {
      "default": { "value": "#EF4444", "type": "color", "$description": "対応不可・通知失敗・エラー" },
      "light":   { "value": "#FEE2E2", "type": "color" }
    },
    "info": {
      "default": { "value": "#3B82F6", "type": "color" },
      "light":   { "value": "#DBEAFE", "type": "color" }
    },
    "text": {
      "primary":   { "value": "#0F172A", "type": "color", "$description": "本文" },
      "secondary": { "value": "#475569", "type": "color", "$description": "サブテキスト" },
      "muted":     { "value": "#94A3B8", "type": "color", "$description": "プレースホルダ・補助" }
    },
    "background": {
      "default": { "value": "#FFFFFF", "type": "color" },
      "subtle":  { "value": "#F8FAFC", "type": "color", "$description": "サイドバー・セクション背景" },
      "card":    { "value": "#FFFFFF", "type": "color" }
    },
    "border": {
      "default": { "value": "#E2E8F0", "type": "color", "$description": "境界線・divider" },
      "strong":  { "value": "#CBD5E1", "type": "color", "$description": "フォーム枠" }
    }
  },

  "font": {
    "family": {
      "sans":  { "value": "Noto Sans JP, Inter, system-ui, sans-serif", "type": "fontFamily" },
      "inter": { "value": "Inter, Noto Sans JP, system-ui, sans-serif", "type": "fontFamily", "$description": "数字・英字（tabular-nums）" },
      "mono":  { "value": "JetBrains Mono, ui-monospace, monospace", "type": "fontFamily" }
    },
    "size": {
      "h1":      { "value": "32px", "type": "dimension" },
      "h2":      { "value": "24px", "type": "dimension" },
      "h3":      { "value": "18px", "type": "dimension" },
      "body":    { "value": "14px", "type": "dimension" },
      "caption": { "value": "12px", "type": "dimension" },
      "kpi":     { "value": "48px", "type": "dimension", "$description": "KPI 強調 (tabular-nums)" },
      "button":  { "value": "14px", "type": "dimension" }
    },
    "weight": {
      "regular":  { "value": 400, "type": "fontWeight" },
      "medium":   { "value": 500, "type": "fontWeight" },
      "semibold": { "value": 600, "type": "fontWeight" },
      "bold":     { "value": 700, "type": "fontWeight" }
    }
  },

  "spacing": {
    "1":  { "value": "4px",  "type": "dimension" },
    "2":  { "value": "8px",  "type": "dimension" },
    "3":  { "value": "12px", "type": "dimension" },
    "4":  { "value": "16px", "type": "dimension" },
    "6":  { "value": "24px", "type": "dimension", "$description": "カード内 padding" },
    "8":  { "value": "32px", "type": "dimension" },
    "12": { "value": "48px", "type": "dimension", "$description": "セクション間" },
    "16": { "value": "64px", "type": "dimension" }
  },

  "radius": {
    "sm": { "value": "4px",  "type": "dimension", "$description": "小要素" },
    "md": { "value": "8px",  "type": "dimension", "$description": "カード" },
    "lg": { "value": "12px", "type": "dimension", "$description": "モーダル" },
    "full": { "value": "9999px", "type": "dimension" }
  },

  "shadow": {
    "card":  { "value": "0 1px 2px rgba(15, 23, 42, 0.06)",  "type": "shadow" },
    "pop":   { "value": "0 4px 16px rgba(15, 23, 42, 0.08)", "type": "shadow" },
    "modal": { "value": "0 10px 25px rgba(15, 23, 42, 0.10)", "type": "shadow" }
  },

  "size": {
    "input":  { "value": "40px", "type": "dimension" },
    "button": {
      "lg": { "value": "48px", "type": "dimension" },
      "md": { "value": "40px", "type": "dimension" },
      "sm": { "value": "32px", "type": "dimension" }
    },
    "sidebar":  { "value": "240px", "type": "dimension" },
    "header":   { "value": "56px",  "type": "dimension" },
    "touch":    { "value": "44px",  "type": "dimension", "$description": "モバイル最小タップ領域 (§I)" }
  },

  "breakpoint": {
    "sm": { "value": "640px",  "type": "dimension", "$description": "顧客予約 / 業者ポータルのみフル対応" },
    "md": { "value": "1024px", "type": "dimension", "$description": "業者ポータル / 主要管理画面" },
    "lg": { "value": "1024px+", "type": "dimension", "$description": "全画面" }
  },

  "status": {
    "available":   { "tone": "success", "icon": "CheckCircle2",   "label": "対応可" },
    "unavailable": { "tone": "danger",  "icon": "XCircle",        "label": "対応不可" },
    "unconfirmed": { "tone": "warning", "icon": "Clock",          "label": "業者未確認" },
    "failed":      { "tone": "danger",  "icon": "AlertTriangle",  "label": "通知失敗" },
    "moving":      { "tone": "info",    "icon": "Truck",          "label": "移動中" },
    "done":        { "tone": "muted",   "icon": "Flag",           "label": "完了" },
    "confirmed":   { "tone": "success", "icon": "CheckCircle2",   "label": "確定" },
    "tentative":   { "tone": "warning", "icon": "Clock",          "label": "仮予約" },
    "cancelled":   { "tone": "muted",   "icon": "Ban",            "label": "キャンセル" },
    "inprogress":  { "tone": "info",    "icon": "Wrench",         "label": "作業中" }
  },

  "permission_cell": {
    "$description": "F.15 権限マトリクスのセル配色 (§A.8.5 R/W/C → 閲覧/更新/作成)",
    "read":   { "bg": "{color.background.subtle.value}",   "fg": "{color.text.secondary.value}", "label": "閲覧" },
    "write":  { "bg": "{color.info.light.value}",          "fg": "#1E40AF",                       "label": "更新" },
    "create": { "bg": "{color.primary.light.value}",       "fg": "{color.primary.default.value}", "label": "作成" },
    "denied": { "bg": "transparent",                       "fg": "{color.text.muted.value}",      "label": "—" },
    "scope": {
      "$description": "データ範囲の修飾子",
      "self":  "自分のみ",
      "store": "自店のみ"
    }
  }
}
